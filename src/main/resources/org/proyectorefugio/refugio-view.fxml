<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proyectorefugio.controller.PrincipalController">
   <top>
      <MenuBar prefHeight="26.0" prefWidth="1499.0" style="-fx-background-color: #3B668C;" BorderPane.alignment="CENTER">
        <menus>
          <Menu mnemonicParsing="false" text="Ayuda">
            <items>
              <MenuItem mnemonicParsing="false" text="Close" />
            </items>
          </Menu>
          <Menu disable="true" mnemonicParsing="false" text="Salir">
            <items>
              <MenuItem mnemonicParsing="false" text="Delete" />
            </items>
          </Menu>
        </menus>
         <cursor>
            <Cursor fx:constant="OPEN_HAND" />
         </cursor>
      </MenuBar>
   </top>
   <left>
      <VBox alignment="TOP_CENTER" prefHeight="678.0" prefWidth="330.0" spacing="28.0" style="-fx-background-color: #3A758C; -fx-border-width: 0 5 0 0; -fx-border-color: #ffffff;" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#abrirAnimales" prefHeight="56.0" prefWidth="211.0" text="Animales">
               <font>
                  <Font name="Arial" size="24.0" />
               </font>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
               <padding>
                  <Insets bottom="10.0" left="50.0" right="50.0" top="10.0" />
               </padding>
            </Button>
            <Button mnemonicParsing="false" onAction="#abrirVoluntarios" prefHeight="56.0" prefWidth="211.0" text="Voluntarios">
               <font>
                  <Font name="Arial" size="24.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="40.0" right="40.0" top="10.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#abrirAdoptantes" prefHeight="56.0" prefWidth="211.0" text="Personas">
               <font>
                  <Font name="Arial" size="24.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="40.0" right="40.0" top="10.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#abrirUbicaciones" prefHeight="56.0" prefWidth="211.0" text="Ubicaciones">
               <font>
                  <Font name="Arial" size="24.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="40.0" right="40.0" top="10.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
            <Region prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#volverInicio" prefHeight="20.0" prefWidth="78.0" text="INICIO">
               <font>
                  <Font name="Arial" size="12.0" />
               </font>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
            </Button>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <opaqueInsets>
            <Insets right="1.0" />
         </opaqueInsets>
         <padding>
            <Insets bottom="15.0" top="37.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="panelContenido" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: #F2EDDC;" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
