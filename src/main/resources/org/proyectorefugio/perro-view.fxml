<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="643.0" prefWidth="1066.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.proyectorefugio.controller.PerroController">
   <children>
      <Text layoutX="519.0" layoutY="27.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Guau" />
      <TableView fx:id="tablaPerros" layoutX="65.0" layoutY="62.0" prefHeight="524.0" prefWidth="413.0">
        <columns>
          <TableColumn fx:id="nombreCol" prefWidth="151.0" text="Nombre" />
          <TableColumn fx:id="idCol" prefWidth="43.0" text="Id" />
            <TableColumn fx:id="sexoCol" prefWidth="64.0" text="Sexo" />
            <TableColumn fx:id="razaCol" prefWidth="154.0" text="Raza" />
        </columns>
      </TableView>
      <CheckBox fx:id="adoptado" layoutX="519.0" layoutY="120.0" mnemonicParsing="false" onAction="#seleccionAdoptado" prefHeight="17.0" prefWidth="105.0" text="Adoptados" />
      <CheckBox fx:id="noAdoptado" layoutX="519.0" layoutY="97.0" mnemonicParsing="false" onAction="#seleccionNoAdoptado" prefWidth="142.0" selected="true" text="No adoptados" />
      <Button layoutX="519.0" layoutY="151.0" mnemonicParsing="false" text="Adoptar" />
      <HBox layoutX="65.0" layoutY="599.0" prefHeight="29.0" prefWidth="413.0" spacing="15.0">
         <children>
            <Button fx:id="añadirPerroBD" mnemonicParsing="false" onAction="#botonInsertarPerro" text="Añadir" />
            <Button mnemonicParsing="false" text="Buscar" />
            <Button mnemonicParsing="false" text="Modificar" />
            <Button mnemonicParsing="false" text="Eliminar" />
         </children>
      </HBox>
      <Label fx:id="informacionAdicional" layoutX="519.0" layoutY="211.0" lineSpacing="10.0" prefHeight="375.0" prefWidth="477.0" wrapText="true">
         <font>
            <Font name="Arial" size="14.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
